{
  "name": "whatsapp-bot-ai",
  "version": "5.0.0",
  "description": "Professional WhatsApp AI Bot — Zero Error, Production Ready",
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "pair": "node scripts/pair.js",
    "clean": "rimraf sessions data/*.db logs/*.log",
    "update": "npm update && npm run build",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker build -t whatsapp-bot-ai .",
    "docker:run": "docker run -d --restart always --env-file .env whatsapp-bot-ai",
    "env:validate": "node scripts/validate-env.js"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.10",
    "@vitalets/google-translate-api": "^9.2.0",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^11.8.0",
    "chalk": "^5.4.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.8.0",
    "fs-extra": "^11.3.0",
    "gradient-string": "^3.0.0",
    "html-to-text": "^9.0.5",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "node-cron": "^3.0.3",
    "node-html-parser": "^6.1.13",
    "node-schedule": "^2.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.0",
    "@types/node-schedule": "^2.1.7",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "axios": "^1.7.9",
    "sharp": "^0.33.5"
  },
  "resolutions": {
    "axios": "^1.7.9"
  }
}
